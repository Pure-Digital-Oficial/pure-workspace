generator client {
    provider        = "prisma-client-js"
    output          = "../generated/general"
    previewFeatures = ["multiSchema"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_GENERAL_URL")
    schemas  = ["pure_general", "email_sender"]
}

model application {
    id         String    @id @default(uuid())
    name       String
    status     Status    @default(ACTIVE)
    created_at DateTime  @default(now())
    updated_at DateTime  @default(now())
    deleted_at DateTime?

    users application_x_user[]

    @@schema("pure_general")
}

model application_x_user {
    app_id     String
    user_id    String
    created_at DateTime @default(now())
    updated_at DateTime @default(now())

    user user        @relation(fields: [user_id], references: [id])
    app  application @relation(fields: [app_id], references: [id])

    @@id([user_id, app_id])
    @@schema("pure_general")
}

model auth {
    id           String   @id @default(uuid())
    user_id      String   @unique
    email        String
    password     String?
    access_token String?
    type         AuthType @default(DEFAULT)
    created_at   DateTime @default(now())
    updated_at   DateTime @default(now())
    users        user     @relation(fields: [user_id], references: [id])

    @@schema("pure_general")
}

model user {
    id         String    @id @default(uuid())
    name       String
    nickname  String
    status     Status    @default(PENDING)
    type       UserType  @default(DEFAULT)
    picture    String?
    created_at DateTime  @default(now())
    updated_at DateTime  @default(now())
    deleted_at DateTime?

    auth         auth[]
    applications application_x_user[]
    deleted      confirm_delete_user[]
    data         user_data[]
    contacts     contact_x_user[]
    email_templates email_template[] @relation("CreatedByRelation")
    sent_emails     email_template[] @relation("SenderRelation")
    created_shots   shot[]           @relation("CreatedByRelation")

    @@schema("pure_general")
}

model confirm_delete_user {
    id               String   @id @default(uuid())
    responsibly_user String
    user_id          String
    description      String
    created_at       DateTime @default(now())
    user             user     @relation(fields: [user_id], references: [id])

    @@schema("pure_general")
}

model user_data {
    id         String    @id @default(uuid())
    user_id    String    @unique
    document   String
    birth_date DateTime?
    created_at DateTime  @default(now())
    updated_at DateTime  @default(now())
    user       user      @relation(fields: [user_id], references: [id])

    @@schema("pure_general")
}

model contact_x_user {
    contact_id String
    user_id    String
    created_at DateTime @default(now())
    updated_at DateTime @default(now())

    user    user    @relation(fields: [user_id], references: [id])
    contact contact @relation(fields: [contact_id], references: [id])

    @@id([user_id, contact_id])
    @@schema("pure_general")
}

model contact {
    id        String @id @default(uuid())
    area_code String
    number    String

    status     Status    @default(ACTIVE)
    created_at DateTime  @default(now())
    updated_at DateTime  @default(now())
    deleted_at DateTime?

    users contact_x_user[]

    @@schema("pure_general")
}

enum Status {
    ACTIVE
    INACTIVE
    BLOCKED
    PENDING

    @@schema("pure_general")
}

enum AuthType {
    GOOGLE
    DEFAULT

    @@schema("pure_general")
}

enum UserType {
    DEFAULT
    DEFAULT_ADMIN
    ADMIN
    SYSTEM

    @@schema("pure_general")
}

model email_template {
    id          String   @id @default(uuid())
    created_by_id String
    sender_id String
    created_at DateTime @default(now())
    updated_at DateTime @default(now())
    title      String
    subject    String
    body       String
    status     Status   @default(ACTIVE)
    attachments String

    created_by user @relation("CreatedByRelation", fields: [created_by_id], references: [id])
    sender     user @relation("SenderRelation", fields: [sender_id], references: [id])
    sent_emails shot[] @relation("EmailTemplateRelation")

    @@schema("email_sender")
}

// sugestion name: shot ou email_blast
model shot {
    id          String   @id @default(uuid())
    created_by_id String
    email_template_id String
    title       String
    description String
    scheduled Boolean
    scheduled_at DateTime?
    created_at  DateTime @default(now())
    updated_at  DateTime @default(now())
    status      Status   @default(ACTIVE)

    created_by  user     @relation("CreatedByRelation",fields: [created_by_id], references: [id])
    email_template email_template @relation("EmailTemplateRelation",fields: [email_template_id], references: [id])
    email_lots_x_shots email_lot_x_shot[]
    shot_fired shot_fired[]

    @@schema("email_sender")
}

model email_lot {
  id          String   @id @default(uuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Status   @default(ACTIVE)
  name       String
  description String

  email_lots_x_shots email_lot_x_shot[]
  target_emails target_email[]

  @@schema("email_sender")
}

model email_lot_x_shot {
  email_lot_id String
  shot_id      String
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  email_lot email_lot @relation(fields: [email_lot_id], references: [id])
  shot      shot      @relation(fields: [shot_id], references: [id])

  @@id([email_lot_id, shot_id])
  @@schema("email_sender")
}

model target_email {
  id          String   @id @default(uuid())
  email       String
  status      Status   @default(ACTIVE)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  lot_id     String

  email_lot   email_lot @relation(fields: [lot_id], references: [id])
  shot_fired  shot_fired[]

  @@schema("email_sender")
}

model shot_fired {
  id          String   @id @default(uuid())
  shot_id     String
  target_email_id String
  status      Status   @default(ACTIVE)
  error       String?
  sent_at     DateTime?
  opened_at   DateTime?
  clicked_at  DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())

  shot        shot      @relation(fields: [shot_id], references: [id])
  target_email target_email @relation(fields: [target_email_id], references: [id])

  @@schema("email_sender")
}
